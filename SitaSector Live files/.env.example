# Local / portable defaults — set SITA_MOCK_MODE=0 for real IBM endpoints
SITA_MOCK_MODE=1

# PostgreSQL (optional when mock mode is on)
DATABASE_URL=postgresql://user:pass@localhost:5432/sita_sprint

# IBM MDM (Cloud Pak / SaaS)
IBM_MDM_URL=https://your-mdm-instance.example.com
IBM_MDM_API_KEY=

# IBM Watson Machine Learning (CP4D or cloud.ibm.com)
WATSON_ML_ENDPOINT=https://us-south.ml.cloud.ibm.com
WATSON_API_KEY=
WATSON_ANOMALY_MODEL_ID=
WATSON_AT_RISK_MODEL_ID=
WATSON_NBA_MODEL_ID=

# IBM DataStage / source systems
CORE_BANKING_DB_URL=postgresql://user:pass@localhost:5432/core_banking
LMS_API_URL=
IOT_MQTT_BROKER=

# Sector DB overrides (optional)
FINTECH_DATABASE_URL=
RETAIL_DATABASE_URL=
EDTECH_DATABASE_URL=
