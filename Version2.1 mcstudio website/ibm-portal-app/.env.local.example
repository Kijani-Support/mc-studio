IBM_VERIFY_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=https://<your-deployed-app-url>
NEXTAUTH_SECRET=<random 32+ char string>

# Zite DB REST API — Developer settings tab in your Zite account
ZITE_API_KEY=
ZITE_BASE_URL=https://tables.zite.com/api/v1
