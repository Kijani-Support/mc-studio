# ============================================
# Brevo Email & Newsletter Configuration
# ============================================

# DO NOT USE THIS FILE AS-IS IN PRODUCTION. COPY IT TO .env AND FILL IN YOUR ACTUAL VALUES.

# Brevo API Key (get from Settings → SMTP & API)
BREVO_API_KEY="your_brevo_api_key_here"

# Brevo Contact List ID (get from Contacts → Your List, Use as is)
BREVO_LIST_ID=8

# Brevo Email Template IDs (Use as Is )
BREVO_WELCOME_TEMPLATE_ID=14
BREVO_CONTACT_CONFIRMATION_TEMPLATE_ID=16

# Email Configuration(update with your actual email addresses)
CONTACT_NOTIFICATION_EMAIL=team@modusadora.com
SMTP_FROM_EMAIL=noreply@modusadora.com

# ============================================
# Server Configuration
# ============================================
#currently set to development for testing. Change to production in production environments.
PORT=5000
NODE_ENV=development

# ============================================
# Database Configuration (if applicable)
# ============================================

# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=yourpassword
# DB_NAME=modusadora
